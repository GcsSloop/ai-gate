{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Gate",
  "version": "2.3.4",
  "identifier": "com.aigate.desktop",
  "build": {
    "frontendDist": "../../frontend/dist",
    "beforeBuildCommand": "npm --prefix ../frontend run build -- --mode desktop",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../frontend run dev"
  },
  "app": {
    "windows": [
      {
        "title": "AI Gate",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": [
      "app",
      "dmg"
    ],
    "resources": [
      "bin/routerd-universal-apple-darwin",
      "bin/routerd-x86_64-pc-windows-msvc.exe"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
